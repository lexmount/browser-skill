{
  "name": "@lexmount/browser-skill-installer",
  "version": "0.1.6",
  "description": "Installer for the Lexmount Codex browser skill",
  "type": "module",
  "scripts": {
    "release:npm": "python ./scripts/publish-npm.py",
    "release:npm:check": "python ./scripts/publish-npm.py --skip-publish"
  },
  "bin": {
    "lexmount-browser-skill-install": "./tools/install-skill.mjs"
  },
  "keywords": [
    "codex",
    "skill",
    "lexmount",
    "browser"
  ],
  "author": {
    "name": "Lexmount Team",
    "email": "jiawei.li@lexmount.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/lexmount/browser-skill",
  "repository": {
    "type": "git",
    "url": "https://github.com/lexmount/browser-skill"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": false
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "files": [
    "SKILL.md",
    "REFERENCE.md",
    "README.md",
    "requirements.txt",
    "examples/basic-open.json",
    "examples/retry-demo.json",
    "examples/retry-demo-fail.json",
    "scripts/lexmount_browser.py",
    "tools/install-skill.mjs",
    "tools/install-skill-win.mjs"
  ]
}
